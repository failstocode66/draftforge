# Secrets
.env
.env.local
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Local data store / artifacts
*.db
*.sqlite
*.sqlite3
# Ignore the CONTENTS of data/ (real grounding data: corpus, the real claims
# register, the sqlite db) but NOT the directory itself, so the one committed
# format template below can be re-included. (git cannot un-ignore a file whose
# parent dir is excluded, so we exclude `data/*`, not `data/`.)
data/*
exports/

# ... the obviously-FAKE claims-register format template stays tracked (it is
# NEVER read at runtime; the gate reads only the real, gitignored
# data/claims_register.json). D9: a committed format guide, not real data.
!data/claims_register.EXAMPLE.json

# Manual-smoke / realistic sample data (never committed; D9 open-receivers).
# The real prompts/voice_exemplars.md and data/corpus/ are filled locally only;
# only tests/fixtures/ and *.EXAMPLE.md templates live in git.
scratch/

# The REAL voice-exemplars file (the client's actual past posts) lives in the
# tracked prompts/ dir, so ignore it explicitly to stop real posts being
# committed by accident. The *.EXAMPLE.md format template stays tracked.
prompts/voice_exemplars.md

# Gradio
.gradio/
flagged/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
